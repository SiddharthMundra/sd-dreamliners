root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{py,toml}]
indent_style = space
indent_size = 4

[*.{cpp,h,hpp,ino,c}]
indent_style = space
indent_size = 2

[*.{js,html,css,json,yaml,yml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
