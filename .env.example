# Copy to .env and fill in. Never commit the real .env.

# --- Serial link to M5StickC Plus ---
BELT_SERIAL_URL=/dev/ttyUSB0          # or socket://host:port for fake_m5
BELT_SERIAL_BAUD=500000               # must match M5 Serial.begin()

# --- Audio ---
BELT_MIC_DEVICE=                      # ALSA -D arg; empty = system default
PIPER_VOICE=~/sd-dreamliners/voices/en_US-amy-low.onnx

# --- Vision backend ---
BELT_YOLO_BACKEND=cpu                 # cpu | ei | qaihub
BELT_YOLO_IMGSZ=320
BELT_YOLO_CONF=0.35
BELT_EI_MODEL=~/sd-dreamliners/models/yolo.eim
BELT_QAIHUB_MODEL=~/sd-dreamliners/models/qaihub/yolo26n_qaihub_split/yolo26n_qaihub_320_split_float32.tflite
BELT_QAIHUB_BACKEND=cpu               # cpu | htp
BELT_QAIHUB_HTP_DELEGATE=/usr/lib/libQnnTFLiteDelegate.so

# --- On-device LLM (Ollama) ---
BELT_LLM_MODEL=gemma3:270m
BELT_NAV_LLM_TIMEOUT_S=6.0
KEYWORD_INTENT_ONLY=                  # set to 1 to skip LLM intent routing

# --- Fallback audio-over-serial (legacy) ---
BELT_M5_SERIAL_PCM=
LEGACY_M5_AUDIO=

# --- Wire protocol override (lab use only) ---
BELT_WIRE_JSON=                       # 1 switches to JSON (hardware stays text)

# --- Webapp ---
BELT_WEB_HOST=0.0.0.0
BELT_WEB_PORT=8000

# --- Bring-up and diagnostics ---
BELT_LOG_DIR=/tmp/belt-logs
BELT_WARMUP=1
BELT_MEMWATCH=1

# --- Last-resort cloud voice (do not enable for judging) ---
OPENAI_VOICE=
